
{
  "name": "inventory_items",
  "options": {
    "validator": {
      "$jsonSchema": {
        "bsonType": "object",
        "required": ["item_id", "name", "category", "quantity", "unit_price", "created_at"],
        "properties": {
          "item_id": {
            "bsonType": "string",
            "description": "Código único do item"
          },
          "name": {
            "bsonType": "string",
            "description": "Nome do item"
          },
          "description": {
            "bsonType": "string",
            "description": "Descrição detalhada"
          },
          "category": {
            "bsonType": "string",
            "enum": ["cabos", "disjuntores", "tomadas", "interruptores", "lampadas", "condutos", "ferramentas", "equipamentos"],
            "description": "Categoria do item"
          },
          "quantity": {
            "bsonType": "int",
            "minimum": 0,
            "description": "Quantidade em estoque"
          },
          "minimum_stock": {
            "bsonType": "int",
            "minimum": 0,
            "description": "Estoque mínimo"
          },
          "unit_price": {
            "bsonType": "number",
            "minimum": 0,
            "description": "Preço unitário"
          },
          "supplier": {
            "bsonType": "string",
            "description": "Fornecedor principal"
          },
          "supplier_code": {
            "bsonType": "string",
            "description": "Código do fornecedor"
          },
          "unit": {
            "bsonType": "string",
            "enum": ["unidade", "metro", "rolo", "caixa", "pacote", "kg"],
            "description": "Unidade de medida"
          },
          "location": {
            "bsonType": "string",
            "description": "Localização no estoque"
          },
          "last_purchase_date": {
            "bsonType": "string",
            "title": "datetime",
            "description": "Data da última compra"
          },
          "creator": {
            "bsonType": "string",
            "description": "Responsável pelo cadastro"
          },
          "created_at": {
            "bsonType": "string",
            "title": "datetime",
            "description": "Data de criação"
          },
          "updated_at": {
            "bsonType": "string",
            "title": "datetime",
            "description": "Data da última atualização"
          }
        },
        "additionalProperties": true
      }
    },
    "validationLevel": "moderate",
    "validationAction": "warn"
  }
}
